<Window x:Class="ScreenAnnotator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="屏幕标注白板"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#01000000"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Focusable="True">
    <Grid x:Name="Root">
        <Canvas x:Name="TextHost" IsHitTestVisible="True" Panel.ZIndex="10"/>
    </Grid>
</Window>
