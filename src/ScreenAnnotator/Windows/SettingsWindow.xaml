<Window x:Class="ScreenAnnotator.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快捷键设置"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="460" Height="420"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize"
        Background="#FFF7F7F7"
        FontFamily="Microsoft YaHei UI">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="快捷键设置" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="#FF555555" Margin="0,0,0,12"
                   Text="录制：按下键盘、鼠标中键/侧键或拨动滚轮（Esc 取消）。也可手动输入，如 F6、MouseMiddle、滚轮上、Ctrl+鼠标中键。单独左键/右键不可绑定（右键已用于移动/框选）；可绑中键、侧键、滚轮及带修饰键的鼠标组合。全局单键/鼠标可能冲突，失败请换键。"/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="恢复默认" Width="90" Margin="0,0,8,0" Click="OnReset" Padding="8,4"/>
            <Button Content="保存并应用" Width="100" Margin="0,0,8,0" Click="OnSave" Padding="8,4"
                    IsDefault="True"/>
            <Button Content="关闭" Width="80" Click="OnClose" Padding="8,4" IsCancel="True"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="HotkeyList"/>
        </ScrollViewer>
    </DockPanel>
</Window>
