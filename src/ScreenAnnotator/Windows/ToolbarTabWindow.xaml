<Window x:Class="ScreenAnnotator.Windows.ToolbarTabWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="展开工具栏"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        Width="100" Height="26"
        Focusable="False"
        Cursor="Arrow"
        ForceCursor="True"
        MouseEnter="OnChromeMouseEnter"
        MouseLeave="OnChromeMouseLeave"
        MouseMove="OnChromeMouseMove">
    <Border x:Name="RootBorder" Background="#AAF5F5F5" BorderBrush="#60FFFFFF" BorderThickness="1"
            CornerRadius="0,0,8,8" Cursor="Arrow" MouseLeftButtonUp="OnExpandClick">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.2" Direction="270"/>
        </Border.Effect>
        <TextBlock x:Name="LabelText" Text="展开" HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontFamily="Microsoft YaHei UI" FontSize="12" FontWeight="SemiBold"
                   Foreground="#FF1A1A1A" IsHitTestVisible="False"/>
    </Border>
</Window>
