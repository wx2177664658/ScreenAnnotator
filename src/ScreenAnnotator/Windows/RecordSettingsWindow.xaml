<Window x:Class="ScreenAnnotator.Windows.RecordSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="开始录屏"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False"
        Topmost="True"
        FontFamily="Microsoft YaHei UI"
        Background="#FFF5F5F5">
    <Border Padding="16" MinWidth="420">
        <StackPanel>
            <TextBlock Text="保存为" FontSize="12" Foreground="#FF555555" Margin="0,0,0,4"/>
            <DockPanel Margin="0,0,0,12">
                <Button DockPanel.Dock="Right" Content="浏览…" Padding="10,4" Margin="8,0,0,0"
                        Click="OnBrowse" Focusable="False"/>
                <TextBox x:Name="PathBox" Height="28" VerticalContentAlignment="Center" Padding="6,2"/>
            </DockPanel>

            <TextBlock Text="音频（可选，默认关闭）" FontSize="12" Foreground="#FF555555" Margin="0,0,0,6"/>
            <CheckBox x:Name="ChkMic" Content="麦克风" Margin="0,0,0,6" IsChecked="False"/>
            <CheckBox x:Name="ChkSystem" Content="系统声音" Margin="0,0,0,14" IsChecked="False"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Width="80" Padding="8,4" Margin="0,0,8,0" Click="OnCancel" IsCancel="True"/>
                <Button Content="开始录制" Width="96" Padding="8,4" Click="OnStart" IsDefault="True"
                        FontWeight="SemiBold"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
