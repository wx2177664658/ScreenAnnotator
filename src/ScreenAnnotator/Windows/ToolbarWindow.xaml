<Window x:Class="ScreenAnnotator.Windows.ToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="工具栏"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Focusable="False"
        Cursor="Arrow"
        ForceCursor="True"
        MouseEnter="OnChromeMouseEnter"
        MouseLeave="OnChromeMouseLeave"
        MouseMove="OnChromeMouseMove">
    <!-- 浅色半透明玻璃底（非纯白） -->
    <Border x:Name="RootBorder" Background="#AAF5F5F5" BorderBrush="#60FFFFFF"
            BorderThickness="0,0,0,1" CornerRadius="0,0,10,10" Padding="8,5,8,6"
            Cursor="Arrow">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.22" Direction="270"/>
        </Border.Effect>
        <StackPanel>
            <!-- 第 0 行：内容形态 A/B + 交互态 + 屏幕 -->
            <DockPanel Margin="0,0,0,4" LastChildFill="False">
                <TextBlock x:Name="BrandText" Text="屏幕标注" FontFamily="Microsoft YaHei UI" FontSize="12"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="#FF1A1A1A"/>
                <Border BorderBrush="#66FFFFFF" BorderThickness="1" CornerRadius="4" Padding="1"
                        Background="#55FFFFFF" VerticalAlignment="Center" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnContentOverlay" Content="屏幕标注" Click="OnContentOverlay"
                                Padding="8,2" Margin="0,0,1,0" Focusable="False"
                                FontFamily="Microsoft YaHei UI" FontSize="12"
                                Cursor="Arrow" ToolTip="模式 A：透明叠加标注"/>
                        <Button x:Name="BtnContentBoard" Content="空白白板" Click="OnContentBoard"
                                Padding="8,2" Focusable="False"
                                FontFamily="Microsoft YaHei UI" FontSize="12"
                                Cursor="Arrow" ToolTip="模式 B：不透明白板（不点穿桌面）"/>
                    </StackPanel>
                </Border>
                <Border BorderBrush="#66FFFFFF" BorderThickness="1" CornerRadius="4" Padding="1"
                        Background="#55FFFFFF" VerticalAlignment="Center" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnModeActive" Content="标注" Click="OnModeActive"
                                Padding="8,2" Margin="0,0,1,0" Focusable="False"
                                FontFamily="Microsoft YaHei UI" FontSize="12"
                                Cursor="Arrow" ToolTip="标注模式：可绘制"/>
                        <Button x:Name="BtnModePassthrough" Content="穿透" Click="OnModePassthrough"
                                Padding="8,2" Focusable="False"
                                FontFamily="Microsoft YaHei UI" FontSize="12"
                                Cursor="Arrow" ToolTip="穿透模式：笔迹仍可见，点击下层"/>
                    </StackPanel>
                </Border>
                <TextBlock Text="屏幕" FontFamily="Microsoft YaHei UI" FontSize="11"
                           Foreground="#FF555555" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox x:Name="ScreenCombo" Width="168" Height="24" FontFamily="Microsoft YaHei UI"
                          FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"
                          SelectionChanged="OnScreenChanged" Cursor="Arrow"/>
                <TextBlock x:Name="StatusText" Margin="4,0,0,0"
                           FontFamily="Microsoft YaHei UI" FontSize="11"
                           Foreground="#FF555555" VerticalAlignment="Center" Text=""/>
                <Button DockPanel.Dock="Right" Content="收起 ▲" Click="OnCollapse"
                        ToolTip="收起工具栏（仍可绘制）" Padding="8,2" Margin="8,0,0,0"
                        FontFamily="Microsoft YaHei UI" FontSize="12" Focusable="False"
                        Cursor="Arrow" VerticalAlignment="Center"/>
            </DockPanel>

            <!-- 第 1 行：主操作（工具 + 编辑/文件） -->
            <WrapPanel VerticalAlignment="Center">
                <WrapPanel x:Name="ToolPanel" VerticalAlignment="Center"/>

                <Border Width="1" Height="18" Background="#66000000" Margin="6,0,6,0" VerticalAlignment="Center"/>

                <!-- 折叠入口：颜色 / 粗细 / 字号 -->
                <ToggleButton x:Name="BtnColorToggle" Click="OnColorToggle" Margin="0,0,4,2"
                              Padding="6,3" Focusable="False" Cursor="Arrow"
                              FontFamily="Microsoft YaHei UI" FontSize="12" ToolTip="颜色">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="颜色" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <Border x:Name="ColorSwatch" Width="14" Height="14" CornerRadius="2"
                                BorderBrush="#88000000" BorderThickness="1" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <Popup x:Name="ColorPopup" PlacementTarget="{Binding ElementName=BtnColorToggle}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                       Closed="OnColorPopupClosed">
                    <Border Background="#EEF5F5F5" BorderBrush="#66000000" BorderThickness="1"
                            CornerRadius="6" Padding="8" Cursor="Arrow">
                        <StackPanel Orientation="Horizontal">
                            <WrapPanel x:Name="ColorPanel" VerticalAlignment="Center"/>
                            <Button Content="自定义…" Click="OnCustomColor" Margin="8,0,0,0"
                                    Padding="6,2" FontFamily="Microsoft YaHei UI" FontSize="12"
                                    Cursor="Arrow" Focusable="False"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <ToggleButton x:Name="BtnStrokeToggle" Click="OnStrokeToggle" Margin="0,0,4,2"
                              Padding="6,3" Focusable="False" Cursor="Arrow"
                              FontFamily="Microsoft YaHei UI" FontSize="12" ToolTip="粗细">
                    <TextBlock x:Name="StrokeSummary" Text="粗细·中"/>
                </ToggleButton>
                <Popup x:Name="StrokePopup" PlacementTarget="{Binding ElementName=BtnStrokeToggle}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                       Closed="OnStrokePopupClosed">
                    <Border Background="#EEF5F5F5" BorderBrush="#66000000" BorderThickness="1"
                            CornerRadius="6" Padding="8" Cursor="Arrow">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="StrokeThin" Content="细" GroupName="Stroke" Margin="0,0,10,0"
                                         Checked="OnStrokeChanged" FontFamily="Microsoft YaHei UI" Cursor="Arrow"/>
                            <RadioButton x:Name="StrokeMedium" Content="中" GroupName="Stroke" Margin="0,0,10,0"
                                         IsChecked="True" Checked="OnStrokeChanged" FontFamily="Microsoft YaHei UI" Cursor="Arrow"/>
                            <RadioButton x:Name="StrokeThick" Content="粗" GroupName="Stroke"
                                         Checked="OnStrokeChanged" FontFamily="Microsoft YaHei UI" Cursor="Arrow"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <ToggleButton x:Name="BtnFontToggle" Click="OnFontToggle" Margin="0,0,8,2"
                              Padding="6,3" Focusable="False" Cursor="Arrow"
                              FontFamily="Microsoft YaHei UI" FontSize="12" ToolTip="字号">
                    <TextBlock x:Name="FontSummary" Text="字号·中"/>
                </ToggleButton>
                <Popup x:Name="FontPopup" PlacementTarget="{Binding ElementName=BtnFontToggle}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                       Closed="OnFontPopupClosed">
                    <Border Background="#EEF5F5F5" BorderBrush="#66000000" BorderThickness="1"
                            CornerRadius="6" Padding="8" Cursor="Arrow">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="FontSmall" Content="小" GroupName="Font" Margin="0,0,10,0"
                                         Checked="OnFontChanged" FontFamily="Microsoft YaHei UI" Cursor="Arrow"/>
                            <RadioButton x:Name="FontMedium" Content="中" GroupName="Font" Margin="0,0,10,0"
                                         IsChecked="True" Checked="OnFontChanged" FontFamily="Microsoft YaHei UI" Cursor="Arrow"/>
                            <RadioButton x:Name="FontLarge" Content="大" GroupName="Font"
                                         Checked="OnFontChanged" FontFamily="Microsoft YaHei UI" Cursor="Arrow"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <Border Width="1" Height="18" Background="#66000000" Margin="2,0,6,0" VerticalAlignment="Center"/>

                <Button Content="撤销" Click="OnUndo" ToolTip="撤销" Margin="0,0,3,2" Padding="7,3"
                        FontFamily="Microsoft YaHei UI" FontSize="12" Focusable="False" Cursor="Arrow"/>
                <Button Content="重做" Click="OnRedo" ToolTip="重做" Margin="0,0,3,2" Padding="7,3"
                        FontFamily="Microsoft YaHei UI" FontSize="12" Focusable="False" Cursor="Arrow"/>
                <Button Content="清屏" Click="OnClear" ToolTip="清屏" Margin="0,0,3,2" Padding="7,3"
                        FontFamily="Microsoft YaHei UI" FontSize="12" Focusable="False" Cursor="Arrow"/>
                <Button Content="保存" Click="OnSave" ToolTip="保存工程" Margin="0,0,3,2" Padding="7,3"
                        FontFamily="Microsoft YaHei UI" FontSize="12" Focusable="False" Cursor="Arrow"/>
                <Button Content="打开" Click="OnOpen" ToolTip="打开工程" Margin="0,0,3,2" Padding="7,3"
                        FontFamily="Microsoft YaHei UI" FontSize="12" Focusable="False" Cursor="Arrow"/>
                <Button Content="导出PNG" Click="OnExport" ToolTip="导出透明底 PNG" Margin="0,0,3,2" Padding="7,3"
                        FontFamily="Microsoft YaHei UI" FontSize="12" Focusable="False" Cursor="Arrow"/>
                <Button Content="截屏" Click="OnCapture" ToolTip="截屏带标注" Margin="0,0,3,2" Padding="7,3"
                        FontFamily="Microsoft YaHei UI" FontSize="12" Focusable="False" Cursor="Arrow"/>
                <Button x:Name="BtnRecord" Content="录制" Click="OnRecord" ToolTip="录制选中屏（含标注）" Margin="0,0,3,2" Padding="7,3"
                        FontFamily="Microsoft YaHei UI" FontSize="12" Focusable="False" Cursor="Arrow"/>
                <Button Content="帮助" Click="OnHelp" ToolTip="使用说明" Margin="0,0,3,2" Padding="7,3"
                        FontFamily="Microsoft YaHei UI" FontSize="12" Focusable="False" Cursor="Arrow"/>
                <Button Content="设置" Click="OnSettings" ToolTip="快捷键设置" Margin="0,0,3,2" Padding="7,3"
                        FontFamily="Microsoft YaHei UI" FontSize="12" Focusable="False" Cursor="Arrow"/>
                <Button Content="退出" Click="OnExit" ToolTip="退出应用" Margin="0,0,0,2" Padding="7,3"
                        FontFamily="Microsoft YaHei UI" FontSize="12" Focusable="False" Cursor="Arrow"/>
            </WrapPanel>
        </StackPanel>
    </Border>
</Window>
